
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the system, including their identification, role, and departmental assignment.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string", "description": "The unique BIM ID of the user (e.g., BIM0100)" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Agent", "Specialist"] },
        "department": { "type": "string" }
      },
      "required": ["id", "username", "name", "email", "role", "department"]
    },
    "ComplaintTicket": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ComplaintTicket",
      "type": "object",
      "description": "Represents a complaint ticket with enhanced fields for intake method and detailed descriptions.",
      "properties": {
        "id": { "type": "string" },
        "ticketID": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "customerName": { "type": "string" },
        "cif": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "serviceType": { "type": "string" },
        "subIssue": { "type": "string" },
        "intakeMethod": { "type": "string" },
        "description": { "type": "string" },
        "createdByAgentId": { "type": "string" },
        "createdByAgentName": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["customerName", "cif", "phoneNumber", "serviceType", "intakeMethod", "subIssue", "description"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile" }
      },
      {
        "path": "/tickets/{ticketId}",
        "definition": { "entityName": "ComplaintTicket" }
      },
      {
        "path": "/settings/system-config",
        "definition": { "entityName": "SystemConfig" }
      }
    ]
  }
}
