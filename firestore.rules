rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات المساعدة ---

    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من صلاحيات المدير عبر مجموعة admins باستخدام exists
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // جلب بيانات المستخدم بشكل آمن
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : {"department": "none", "role": "none"};
    }

    // --- القواعد ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      // السماح بالقراءة (get & list)
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource.data.createdByAgentId == request.auth.uid) || 
        (resource.data.assignedToSpecialistId == request.auth.uid) ||
        (getUserData().department == resource.data.serviceType)
      );

      allow create: if isSignedIn() && request.resource.data.createdByAgentId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.createdByAgentId == request.auth.uid) || 
        (resource.data.assignedToSpecialistId == request.auth.uid) ||
        (getUserData().department == resource.data.serviceType)
      );

      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read: if isSignedIn() && (
          isAdmin() || 
          (resource.data.ticketCreatedByAgentId == request.auth.uid) || 
          (resource.data.ticketAssignedToSpecialistId == request.auth.uid) ||
          (getUserData().department == resource.data.ticketServiceType)
        );
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }
  }
}