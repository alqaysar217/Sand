rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONNECTRESOLVE SECURITY RULES
     * 
     * نظام أمني يعتمد على الأدوار (Role-Based) والتبعية الإدارية (Department-Based).
     * تم تحسين القواعد لتدعم الاستعلامات المفلترة (Queries) بشكل تلقائي.
     */

    // --- دالات المساعدة العالمية ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** التحقق من وجود المستخدم في مجموعة المديرين */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /** جلب بيانات المستخدم بأمان */
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : {};
    }

    // --- القواعد ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /tickets/{ticketId} {
      /**
       * منطق الوصول للبلاغات:
       * 1. المدير العام يرى كل شيء.
       * 2. الموظف يرى البلاغات التي أنشأها.
       * 3. الأخصائي يرى البلاغات المسندة إليه أو التابعة لقسمه.
       */
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.createdByAgentId == request.auth.uid || 
        resource.data.assignedToSpecialistId == request.auth.uid ||
        getUserData().department == resource.data.serviceType
      );

      allow create: if isSignedIn() && request.resource.data.createdByAgentId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.createdByAgentId == request.auth.uid || 
        resource.data.assignedToSpecialistId == request.auth.uid ||
        getUserData().department == resource.data.serviceType
      );

      allow delete: if isAdmin();
    }

    match /tickets/{ticketId}/logs/{logId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.ticketCreatedByAgentId == request.auth.uid || 
        resource.data.ticketAssignedToSpecialistId == request.auth.uid ||
        getUserData().department == resource.data.ticketServiceType
      );

      allow create: if isSignedIn() && request.resource.data.changedByUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}