rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من صلاحية المدير (Admin) - بسيطة وسريعة
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // قواعد مجموعة المستخدمين
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // قواعد مجموعة المديرين
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // القواعد النهائية لمجموعة البلاغات (Tickets)
    match /tickets/{ticketId} {
      
      // تبسيط قواعد العرض (List) لتسهيل عمل محرك الاستعلامات
      // يتم السماح بالاستعلام إذا طابق أحد هذه الشروط المنفصلة
      allow list: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && resource.data.createdByAgentId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.assignedToSpecialistId == request.auth.uid;
      allow list: if isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        resource.data.serviceType == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department
      );

      // قواعد القراءة والتحديث
      allow get, update: if isSignedIn() && (
        isAdmin() || 
        resource.data.createdByAgentId == request.auth.uid || 
        resource.data.assignedToSpecialistId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.serviceType == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department)
      );

      // السماح بإنشاء بلاغ جديد
      allow create: if isSignedIn() && request.resource.data.createdByAgentId == request.auth.uid;
      
      // الحذف للمدير فقط
      allow delete: if isAdmin();

      // قواعد السجلات الفرعية (Logs)
      match /logs/{logId} {
        allow read: if isSignedIn() && (
          isAdmin() || 
          resource.data.ticketCreatedByAgentId == request.auth.uid || 
          resource.data.ticketAssignedToSpecialistId == request.auth.uid ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.ticketServiceType == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department)
        );
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }
  }
}