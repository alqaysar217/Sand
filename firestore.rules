rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من وجود مستخدم في قائمة المديرين
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // قواعد المستخدمين
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // قواعد المديرين
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // القواعد النهائية لمجموعة البلاغات (Tickets)
    match /tickets/{ticketId} {
      
      // تقسيم قواعد القائمة (List) لضمان عدم حدوث تعارض في مفسر الاستعلامات
      // يسمح للمدير برؤية الكل
      allow list: if isSignedIn() && isAdmin();
      
      // يسمح للموظف برؤية ما أنشأه فقط
      allow list: if isSignedIn() && resource.data.createdByAgentId == request.auth.uid;
      
      // يسمح للأخصائي برؤية ما هو معين له
      allow list: if isSignedIn() && resource.data.assignedToSpecialistId == request.auth.uid;
      
      // يسمح للأخصائي برؤية ما يخص قسمه
      allow list: if isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        resource.data.serviceType == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department
      );

      // قواعد القراءة الفردية والإنشاء والتحديث
      allow get, create, update: if isSignedIn();
      
      // الحذف للمدير فقط
      allow delete: if isAdmin();

      // قواعد السجلات الفرعية (Logs)
      match /logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}