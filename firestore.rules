
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // قاعدة عامة وبسيطة: أي مستخدم مسجل يمكنه القراءة والكتابة في جميع المجموعات
    // هذا الإعداد مخصص لفترة الفحص والاختبار لضمان عدم ظهور أخطاء الصلاحيات
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
