
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // السماح بالقراءة والكتابة لجميع المستخدمين المسجلين مؤقتاً لغرض الفحص والاختبار
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read, write: if isSignedIn();
    }

    match /tickets/{ticketId} {
      // فتح الصلاحيات مؤقتاً لضمان عمل بقية الأقسام أثناء الفحص
      allow read, write: if isSignedIn();

      match /logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
