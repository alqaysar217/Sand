rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة جلب بيانات المستخدم الحالية
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // قواعد مجموعة المستخدمين والمديرين
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // القواعد النهائية لمجموعة البلاغات (Tickets)
    match /tickets/{ticketId} {
      
      // تبسيط قواعد العرض (List) لضمان عدم حدوث خطأ Permission Denied
      // Firestore يتطلب أن يتطابق الاستعلام مع القاعدة بدقة
      allow list: if isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        resource.data.createdByAgentId == request.auth.uid || 
        resource.data.assignedToSpecialistId == request.auth.uid ||
        resource.data.serviceType == getUserData().department
      );

      // قواعد القراءة الفردية والإنشاء والتحديث
      allow get, update, create: if isSignedIn();
      
      // الحذف للمدير فقط
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));

      // قواعد السجلات الفرعية (Logs)
      match /logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}