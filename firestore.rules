rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات المساعدة ---

    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من صلاحيات المدير عبر مجموعة admins
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // جلب بيانات القسم للمستخدم بأمان
    function getUserDepartment() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.department : 'none';
    }

    // --- القواعد ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      // السماح بالقراءة إذا كان:
      // 1. مديراً.
      // 2. هو من أنشأ البلاغ (للعملاء والموظفين).
      // 3. البلاغ مسند إليه كأخصائي.
      // 4. البلاغ يتبع لقسمه (للأخصائيين).
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource.data.createdByAgentId == request.auth.uid) || 
        (resource.data.assignedToSpecialistId == request.auth.uid) ||
        (getUserDepartment() == resource.data.serviceType)
      );

      allow create: if isSignedIn() && request.resource.data.createdByAgentId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.createdByAgentId == request.auth.uid) || 
        (resource.data.assignedToSpecialistId == request.auth.uid) ||
        (getUserDepartment() == resource.data.serviceType)
      );

      allow delete: if isAdmin();

      // قواعد السجلات (Logs)
      match /logs/{logId} {
        allow read: if isSignedIn() && (
          isAdmin() || 
          (resource.data.ticketCreatedByAgentId == request.auth.uid) || 
          (resource.data.ticketAssignedToSpecialistId == request.auth.uid) ||
          (getUserDepartment() == resource.data.ticketServiceType)
        );
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }
  }
}