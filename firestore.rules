rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CONNECTRESOLVE SECURITY RULES
     * 
     * نظام أمني يعتمد على الأدوار (Role-Based) والتبعية الإدارية (Department-Based).
     * تم تحسين القواعد لتدعم الاستعلامات المفلترة (Queries) بشكل تلقائي.
     */

    // --- دالات المساعدة العالمية ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** التحقق من وجود المستخدم في مجموعة المديرين */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** جلب بيانات المستخدم بأمان مع تجنب الأخطاء في حال عدم الوجود */
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : {};
    }

    // --- القواعد ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /tickets/{ticketId} {
      /**
       * منطق الوصول للبلاغات:
       * 1. المدير العام يرى كل شيء.
       * 2. الموظف (Agent) يرى البلاغات التي أنشأها فقط.
       * 3. الأخصائي (Specialist) يرى البلاغات المسندة إليه أو التابعة لقسمه.
       */
      function canReadTicket(ticketData) {
        let user = getUserData();
        return isAdmin() 
          || ticketData.createdByAgentId == request.auth.uid 
          || ticketData.assignedToSpecialistId == request.auth.uid 
          || user.department == ticketData.serviceType;
      }

      // استخدمنا 'read' لتشمل 'get' و 'list' معاً لضمان عمل الفلترة في الواجهة
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && canReadTicket(resource.data)) ||
        (resource == null) // للسماح بالاستعلامات الأولية التي ستفلتر لاحقاً
      );

      allow create: if isSignedIn() && request.resource.data.createdByAgentId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && canReadTicket(resource.data))
      );

      allow delete: if isAdmin();
    }

    match /tickets/{ticketId}/logs/{logId} {
      function canAccessLog(logData) {
        let user = getUserData();
        return isAdmin() 
          || logData.ticketCreatedByAgentId == request.auth.uid 
          || logData.ticketAssignedToSpecialistId == request.auth.uid 
          || user.department == logData.ticketServiceType;
      }

      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && canAccessLog(resource.data)) ||
        (resource == null)
      );

      allow create: if isSignedIn() && request.resource.data.changedByUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}