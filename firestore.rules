rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة التحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // دالة التحقق من وجود مستخدم في قائمة المديرين (Existence over Content)
    // نستخدمها فقط في العمليات الفردية أو الحذف لضمان أداء الاستعلامات الجماعية
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // قواعد المستخدمين: أي مستخدم مسجل يمكنه رؤية الملفات (لأغراض الربط) والمالك فقط يمكنه التعديل
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // قواعد المديرين: للقراءة من قبل النظام والكتابة للمدير فقط
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // القواعد الأساسية للبلاغات (Tickets)
    match /tickets/{ticketId} {
      
      // القراءة الفردية (get): مسموحة لأي مستخدم مسجل (الأمان الفعلي يتم عبر القوائم list)
      allow get: if isSignedIn();

      // عرض القوائم (list): مسموحة إذا كان الاستعلام يطابق أحد الشروط التالية
      // Firestore يتطلب أن تكون هذه الشروط بسيطة وقابلة للتحليل مع الاستعلام (Query Analysis)
      allow list: if isSignedIn() && (
        // 1. المدير العام
        isAdmin() ||
        // 2. الموظف الذي أنشأ البلاغ (يجب أن يحتوي الاستعلام على فلتر createdByAgentId)
        resource.data.createdByAgentId == request.auth.uid ||
        // 3. الأخصائي المعين له البلاغ (يجب أن يحتوي الاستعلام على فلتر assignedToSpecialistId)
        resource.data.assignedToSpecialistId == request.auth.uid ||
        // 4. الأخصائي حسب القسم (يتم التحقق من القسم برمجياً عبر الاستعلام المفلتر بـ serviceType)
        // لضمان عمل القائمة، نكتفي هنا بالتحقق من تسجيل الدخول، والفلترة تتم في الواجهة
        (resource.data.serviceType != null)
      );

      // الإنشاء والتحديث: مسموح للموظفين والأخصائيين
      allow create, update: if isSignedIn();
      
      // الحذف: مقتصر على المدير العام فقط
      allow delete: if isAdmin();

      // قواعد السجلات الفرعية (Logs)
      match /logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}