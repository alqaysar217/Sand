rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // قاعدة عامة تسمح بالوصول لجميع المستخدمين المسجلين لضمان استقرار الفحص
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // قواعد مخصصة لمجموعة التذاكر لدعم استعلامات الـ List المفلترة
    match /tickets/{ticketId} {
      allow read, list, write: if request.auth != null;
      
      // دعم الاستعلامات الفرعية للسجلات
      match /logs/{logId} {
        allow read, list, write: if request.auth != null;
      }
    }
    
    // قواعد المستخدمين
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}